      "blog-engine",
      "faq-accordion",
      "contact-form-alt",
      "footer-complex",
    ],
    "not-sure": [
      "responsive-layout",
      "ssg-engine",
      "responsive-navbar",
      "hero-section",
      "trust-badges",
      "service-highlights",
      "contact-form-alt",
      "footer-complex",
      "sticky-mobile-cta",
    ],
  };

  const blockLabels: Record<string, string> = {
    "responsive-layout": "Mobile & Tablet Ready",
    "ssg-engine": "Super-Fast Load Speeds",
    "responsive-navbar": "Navigation Bar",
    "hero-section": "Opening Statement",
    "trust-badges": "Trust Strip",
    "fleet-showcase": "Product & Service Cards",
    "pricing-table": "Pricing — Clear & Upfront",
    "services-reservation": "How to Book",
    "service-highlights": "Why Choose You",
    "google-reviews": "Customer Reviews",
    "faq-accordion": "Common Questions Answered",
    "contact-form-alt": "Multi-Channel Contact",
    "contact-form": "Simple Contact Form",
    "location-maps": "Where to Find You",
    "footer-complex": "Professional Footer",
    "sticky-mobile-cta": "Mobile Booking Bar",
    "whatsapp-strategy": "WhatsApp Deep Links",
    "blog-engine": "Easy-Post News & Blog",
    "portfolio-grid": "Gallery of Work",
    "ai-personalization": "Adaptive Experience",
    "performance-optimization": "Google Speed Guarantee",
  };

  // ── State ─────────────────────────────────────────────────────────────
  interface Answers {
    businessType: string | null;
    primaryGoal: string | null;
    assets: string[];
    timeline: string | null;
  }

  let answers: Answers = {
    businessType: null,
    primaryGoal: null,
    assets: [],
    timeline: null,
  };

  // ── Persistence & Initialization ─────────────────────────────────────
  function init() {
    const saved = profileData.get();
    if (
      !saved.businessType &&
      !saved.primaryGoal &&
      saved.assets.length === 0 &&
      !saved.timeline
    )
      return;

    if (saved.businessType) {
      answers.businessType = saved.businessType;
      const input = document.querySelector(
        `.q1-option input[value="${saved.businessType}"]`,
      ) as HTMLInputElement;
      if (input) {
        input.checked = true;
        unlockQuestion(2, false);
      }
    }

    if (saved.primaryGoal) {
      answers.primaryGoal = saved.primaryGoal;
      const input = document.querySelector(
        `.q2-option input[value="${saved.primaryGoal}"]`,
      ) as HTMLInputElement;
      if (input) {
        input.checked = true;
        unlockQuestion(3, false);
      }
    }

    if (saved.assets && saved.assets.length > 0) {
      answers.assets = saved.assets;
      saved.assets.forEach((val) => {
        const input = document.querySelector(
          `.q3-option input[value="${val}"]`,
        ) as HTMLInputElement;
        if (input) input.checked = true;
      });
      unlockQuestion(4, false);
    }

    if (saved.timeline) {
      answers.timeline = saved.timeline;
      const input = document.querySelector(
        `.q4-option input[value="${saved.timeline}"]`,
      ) as HTMLInputElement;
      if (input) {
        input.checked = true;
      }
    }

    updateProgressBar();
    maybeShowRecommendation(false);
  }

  function persist() {
    profileData.set({
      businessType: answers.businessType || "",
      primaryGoal: answers.primaryGoal || "",
      assets: answers.assets || [],
      timeline: answers.timeline || "",
    });

    // Update recommended blocks in real-time so footer status bar updates
    // This is commented out to prevent premature cart updates.
    // if (answers.businessType) {
    //     const recBlocks = recommendations[answers.businessType] || recommendations['not-sure'];
    //     selectedBlockIds.set(recBlocks);
    // }
  }

  // ── Progressive Unlocking ─────────────────────────────────────────────
  function unlockQuestion(questionNum: number, scroll = true) {
    const next = document.querySelector(
      `[data-question="${questionNum}"]`,
    ) as HTMLElement;
    if (!next) return;

    // Only unlock if it was locked
    const wasLocked = next.classList.contains("text-on-surface-variant");
    if (wasLocked) {
      next.classList.remove("text-on-surface-variant", "pointer-events-none");
      if (scroll) {
        setTimeout(() => {
          next.scrollIntoView({ behavior: "smooth", block: "center" });
        }, 150);
      }
    }
  }

  // ── Event Listeners ───────────────────────────────────────────────────

  // Q1, Q2, Q4 (Radio)
  ["q1", "q2", "q4"].forEach((q) => {
    const inputs = document.querySelectorAll(`.${q}-option input`);
    inputs.forEach((input) => {
      input.addEventListener("mousedown", function (this: HTMLInputElement) {
        // Check if already checked to allow toggle
        if (this.checked) {
          setTimeout(() => {
            this.checked = false;
            const key =
              q === "q1"
                ? "businessType"
                : q === "q2"
                  ? "primaryGoal"
                  : "timeline";
            (answers as any)[key] = null;
            if (q === "q1") selectedBlockIds.set([]); // Clear footer if business type cleared
            persist();
            updateProgressBar();
          }, 0);
        }
      });

      input.addEventListener("change", (e) => {
        const val = (e.target as HTMLInputElement).value;
        if (q === "q1") {
          answers.businessType = val;
          unlockQuestion(2);
        } else if (q === "q2") {
          answers.primaryGoal = val;
          unlockQuestion(3);
        } else {
          answers.timeline = val;
        }
        persist();
        updateProgressBar();
        maybeShowRecommendation();
      });
    });
  });

  // Q3: Assets (checkbox)
  document.querySelectorAll(".q3-option input").forEach((input) => {
    input.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement;
      const val = target.value;
      const checked = target.checked;

      if (val === "has-nothing" && checked) {
        answers.assets = ["has-nothing"];
        document.querySelectorAll(".q3-option input").forEach((cb) => {
          const checkbox = cb as HTMLInputElement;
          if (checkbox.value !== "has-nothing") checkbox.checked = false;
        });
      } else if (checked) {
        answers.assets = answers.assets.filter((a) => a !== "has-nothing");
        const nothingCb = document.querySelector(
          '.q3-option input[value="has-nothing"]',
        ) as HTMLInputElement;
        if (nothingCb) nothingCb.checked = false;
        if (!answers.assets.includes(val)) answers.assets.push(val);
      } else {
        answers.assets = answers.assets.filter((a) => a !== val);
      }

      persist();
      updateProgressBar();
      if (answers.assets.length > 0) unlockQuestion(4);
      maybeShowRecommendation();
    });
  });

  // ── UI Updates ────────────────────────────────────────────────────────
  function updateFooterProgress(
    answeredCount: number,
    questionsFinished: boolean,
    recommendationsVisible: boolean,
  ) {
    const footerZone = document.getElementById("footer-progress-zone");
    if (!footerZone) return;

    // Create container if it doesn't exist
    let progressContainer = document.getElementById("footer-momentum-ui");
    if (!progressContainer) {
      progressContainer = document.createElement("div");
      progressContainer.id = "footer-momentum-ui";
      progressContainer.className =
        "flex items-center gap-8 border-r border-on-background/10 pr-8 mr-4 animate-in fade-in slide-in-from-left-4 duration-500";
      footerZone.prepend(progressContainer);
    }

    // Generate Pips for 4 questions
    const pips = [1, 2, 3, 4]
      .map((i) => {
        const isActive = i <= answeredCount;
        return `<div class="w-3 h-3 border-[2px] border-on-background transition-all duration-300 ${isActive ? "bg-secondary-container" : "opacity-20"}"></div>`;
      })
      .join("");

    const funnelStep = questionsFinished ? 2 : recommendationsVisible ? 2 : 1;

    progressContainer.innerHTML = `
            <div class="flex flex-col gap-1.5">
                <span class="text-[9px] font-black uppercase text-on-surface-variant leading-none">Your Progress</span>
                <div class="flex gap-1">
                    ${pips}
                </div>
            </div>
            <div class="h-8 w-[1px] bg-on-background/10"></div>
            <div class="flex flex-col">
                <span class="text-[9px] font-black uppercase text-on-surface-variant leading-none mb-1">Funnel Step</span>
                <div class="flex items-center gap-2">
                    <span class="font-headline font-black text-sm uppercase tracking-tight">${funnelStep}/3</span>
                    <span class="text-[10px] font-bold uppercase opacity-60">${questionsFinished ? "Decision" : "Profiling"}</span>
                </div>
            </div>
        `;
  }

  function updateProgressBar() {
    let answeredCount = 0;

    // Q1: Business Type
    if (answers.businessType && answers.businessType !== "") answeredCount++;

    // Q2: Primary Goal
    if (answers.primaryGoal && answers.primaryGoal !== "") answeredCount++;

    // Q3: Assets (Check if they picked items OR picked "nothing")
    if (answers.assets && answers.assets.length > 0) answeredCount++;

    // Q4: Timeline
    if (answers.timeline && answers.timeline !== "") answeredCount++;

    const recommendationsVisible = !!(
      answers.businessType && answers.primaryGoal
    );
    const questionsFinished = answeredCount === 4;

    // Update the sticky footer indicators
    updateFooterProgress(
      answeredCount,
      questionsFinished,
      recommendationsVisible,
    );

    // Update the top bar indicators
    const line1 = document.getElementById("progress-line-1");
    const line2 = document.getElementById("progress-line-2");
    const step1Num = document.getElementById("step-1-num");
    const step1Text = document.getElementById("step-1-text");
    const step2 = document.getElementById("step-2-ui");
    const step3 = document.getElementById("step-3-ui");

    if (step1Num) {
      if (questionsFinished) {
        step1Num.innerHTML =
          '<span class="material-symbols-outlined text-sm" style="font-variation-settings:\'wght\' 900;">check</span>';
        step1Num.classList.add("bg-secondary-container");
      } else {
        step1Num.textContent = "1";
        step1Num.classList.add("bg-secondary-container");
      }
    }
    if (step1Text) {
      step1Text.textContent = questionsFinished
        ? "Questions Done"
        : `Questions (${answeredCount}/4)`;
    }

    if (line1) {
      const line1Progress = Math.min(answeredCount, 2);
      const percent = (line1Progress / 2) * 100 - 100;
      line1.style.transform = `translateX(${percent}%)`;
    }

    if (step2) {
      step2.classList.toggle("opacity-30", !recommendationsVisible);
      const num = document.getElementById("step-2-num");
      if (num) {
        if (questionsFinished && recommendationsVisible) {
          num.innerHTML =
            '<span class="material-symbols-outlined text-sm" style="font-variation-settings:\'wght\' 900;">check</span>';
          num.classList.add("bg-secondary-container");
        } else {
          num.textContent = "2";
          num.classList.toggle(
            "bg-secondary-container",
            !!recommendationsVisible,
          );
        }
      }
    }

    if (line2) {
      const line2Progress = Math.max(0, answeredCount - 2);
      const percent = (line2Progress / 2) * 100 - 100;
      line2.style.transform = `translateX(${percent}%)`;
    }

    if (step3) {
      step3.classList.toggle("opacity-30", !questionsFinished);
      const num = document.getElementById("step-3-num");
      if (num)
        num.classList.toggle("bg-secondary-container", !!questionsFinished);
    }
  }

  function maybeShowRecommendation(scroll = true) {
    if (!answers.businessType || !answers.primaryGoal) {
      document.getElementById("recommendation")?.classList.add("hidden");
      return;
    }

    const recEl = document.getElementById("recommendation");
    if (!recEl) return;

    const wasHidden = recEl.classList.contains("hidden");
    recEl.classList.remove("hidden");

    if (wasHidden && scroll) {
      setTimeout(
        () => recEl.scrollIntoView({ behavior: "smooth", block: "start" }),
        300,
      );
    }

    // Update Summary
    const summaryEl = document.getElementById("profile-summary");
    if (summaryEl) {
      const items = [
        {
          icon: "business_center",
          label: "Type",
          value: BUSINESS_LABELS[answers.businessType] || "...",
        },
        {
          icon: "flag",
          label: "Goal",
          value: GOAL_LABELS[answers.primaryGoal] || "...",
        },
        {
          icon: "schedule",
          label: "Timeline",
          value: answers.timeline ? TIMELINE_LABELS[answers.timeline] : "...",
        },
      ];

      summaryEl.innerHTML = items
        .map(
          (item) => `
                <div class="flex items-start gap-3 bg-white/5 border border-white/10 p-4">
                    <span class="material-symbols-outlined text-secondary-container text-xl shrink-0">${item.icon}</span>
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-1">${item.label}</p>
                        <p class="font-headline font-black text-sm uppercase tracking-tight">${item.value}</p>
                    </div>
                </div>
            `,
        )
        .join("");
    }

    // Update Preview Pills
    const previewEl = document.getElementById("rec-blocks-preview");
    const recBlocks =
      recommendations[answers.businessType] || recommendations["not-sure"];
    if (previewEl) {
      previewEl.innerHTML = recBlocks
        .map(
          (id: string) => `
                <span class="inline-flex items-center gap-1 px-3 py-1.5 bg-white/10 border border-white/15 text-[11px] font-black uppercase tracking-wide">
                    <span class="material-symbols-outlined text-secondary-container text-xs">check</span>
                    ${blockLabels[id] || id}
                </span>
            `,
        )
        .join("");
    }
  }

  // Final Actions
  document
    .getElementById("go-to-configurator")
    ?.addEventListener("click", () => {
      const recBlocks =
        recommendations[answers.businessType || "not-sure"] ||
        recommendations["not-sure"];
      selectedBlockIds.set(recBlocks);
      window.location.href = "/configurator";
    });

  document
    .getElementById("start-from-scratch")
    ?.addEventListener("click", () => {
      selectedBlockIds.set([]);
      profileData.set({
        businessType: "",
        primaryGoal: "",
        assets: [],
        timeline: "",
      });
      window.location.href = "/configurator";
    });

  init();
</script>
