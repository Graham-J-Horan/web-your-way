---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <div class="fixed inset-0 grainy-overlay z-50 pointer-events-none opacity-5">
  </div>
  <Header showDropdown={false} showBackButton={false} isFunnel={false} />

  <!-- Background watermark -->
  <div
    class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-[0.025] pointer-events-none -z-10 select-none"
  >
    <span
      class="material-symbols-outlined text-[600px] text-on-background"
      style="font-variation-settings: 'FILL' 1;">help_outline</span
    >
  </div>

  <main id="main-content" class="pt-28 pb-48 px-4 md:px-12 max-w-4xl mx-auto">
    <!-- ── Progress indicator ──────────────────────────────────────── -->
    <div class="mb-16 flex items-center gap-3">
      <div
        class="flex items-center gap-2 transition-all duration-500 sm:inline"
        id="step-1-ui"
      >
        <div
          class="w-8 h-8 bg-secondary-container text-on-background flex items-center justify-center font-black text-sm border-[2px] border-on-background transition-colors"
          id="step-1-num"
        >
          1
        </div>
        <span
          class="text-xs font-black uppercase tracking-widest text-on-background hidden md:inline"
          id="step-1-text">Questions</span
        >
      </div>
      <div
        class="flex-grow h-[2px] bg-on-background/10 relative overflow-hidden"
      >
        <div
          id="progress-line-1"
          class="absolute inset-0 bg-secondary-container translate-x-full transition-transform duration-700"
        >
        </div>
      </div>
      <div
        class="flex items-center gap-2 text-on-surface-variant transition-all duration-500 sm:inline"
        id="step-2-ui"
      >
        <div
          class="w-8 h-8 border-[2px] border-on-background text-on-background flex items-center justify-center font-black text-sm transition-colors"
          id="step-2-num"
        >
          2
        </div>
        <span
          class="text-xs font-black uppercase tracking-widest text-on-background hidden md:inline"
          id="step-2-text">Recommendation</span
        >
      </div>
      <div
        class="flex-grow h-[2px] bg-on-background/10 relative overflow-hidden"
      >
        <div
          id="progress-line-2"
          class="absolute inset-0 bg-secondary-container translate-x-[-100%] transition-transform duration-700"
        >
        </div>
      </div>
      <div
        class="flex items-center gap-2 text-on-surface-variant transition-all duration-500 sm:inline"
        id="step-3-ui"
      >
        <div
          class="w-8 h-8 border-[2px] border-on-background text-on-background flex items-center justify-center font-black text-sm transition-colors"
          id="step-3-num"
        >
          3
        </div>
        <span
          class="text-xs font-black uppercase tracking-widest text-on-background hidden md:inline"
          id="step-3-text">Configurator</span
        >
      </div>
    </div>

    <!-- ── Page header ─────────────────────────────────────────────── -->
    <section class="mb-16">
      <div class="relative inline-block mb-6">
        <h1
          class="text-5xl md:text-7xl font-black font-headline uppercase leading-[0.88] tracking-tighter relative z-10 text-on-background"
        >
          First,<br />tell us<br /><span class="text-primary-container"
            >about you</span
          >
        </h1>
        <div
          class="absolute -right-3 -bottom-2 bg-secondary-container w-3/4 h-3 -z-0"
        >
        </div>
      </div>
      <p
        class="text-lg font-bold text-on-background leading-relaxed max-w-xl mt-6"
      >
        Four quick questions. No technical knowledge needed. Your answers help
        us suggest the right starting point — you can change anything
        afterwards.
      </p>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
             THE FOUR QUESTIONS
        ══════════════════════════════════════════════════════════════ -->
    <div class="space-y-14" id="question-flow">
      <!-- ── Q1: What kind of business ──────────────────────────── -->
      <fieldset class="question-block" data-question="1">
        <legend class="sr-only"
          >1. What kind of business do you have? Pick the one that fits best —
          it helps us suggest the right pages.</legend
        >
        <div class="flex items-start gap-4 mb-6">
          <div
            class="w-10 h-10 bg-on-background dark:bg-white text-white dark:text-on-background flex items-center justify-center font-black text-lg shrink-0 mt-1"
          >
            1
          </div>
          <div>
            <h2
              class="text-2xl md:text-3xl font-black font-headline uppercase tracking-tighter text-on-background leading-tight"
            >
              What kind of business do you have?
            </h2>
            <p class="text-sm font-medium opacity-60 text-on-background mt-1">
              Pick the one that fits best — it helps us suggest the right pages.
            </p>
          </div>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-4 pl-14"
          id="q1-options"
        >
          {
            [
              {
                value: "local-service",
                icon: "build",
                label: "A local service business",
                sub: "Plumber, cleaner, van hire, mechanic, electrician…",
              },
              {
                value: "restaurant-cafe",
                icon: "restaurant",
                label: "A restaurant or café",
                sub: "Food, drink, hospitality, takeaway…",
              },
              {
                value: "retail-ecommerce",
                icon: "storefront",
                label: "A shop or online store",
                sub: "Selling products — in person or online…",
              },
              {
                value: "creative-portfolio",
                icon: "brush",
                label: "A creative or freelancer",
                sub: "Photographer, designer, artist, consultant…",
              },
              {
                value: "professional-services",
                icon: "business_center",
                label: "A professional practice",
                sub: "Solicitor, accountant, estate agent, clinic…",
              },
              {
                value: "not-sure",
                icon: "help_outline",
                label: "Not sure / something else",
                sub: "We'll suggest a good starting point for you.",
              },
            ].map((opt) => (
              <label class="q1-option group relative flex items-start gap-4 p-5 bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white cursor-pointer hard-shadow-sm hover:-translate-y-1 hover:-translate-x-1 transition-all has-[:checked]:border-secondary-container has-[:checked]:bg-secondary-container/10">
                <input
                  type="radio"
                  name="business-type"
                  value={opt.value}
                  class="sr-only"
                />
                <div class="w-8 h-8 border-[3px] border-on-background dark:border-white flex-shrink-0 flex items-center justify-center group-has-[:checked]:bg-secondary-container transition-colors mt-0.5">
                  <span
                    class="material-symbols-outlined text-sm text-on-background hidden group-has-[:checked]:block"
                    style="font-variation-settings: 'wght' 900;"
                  >
                    check
                  </span>
                </div>
                <div class="flex-grow">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-xl text-on-surface-variant group-has-[:checked]:opacity-100  transition-opacity">
                      {opt.icon}
                    </span>
                    <span class="font-headline font-black text-base uppercase tracking-tight text-on-background">
                      {opt.label}
                    </span>
                  </div>
                  <p class="text-xs font-medium opacity-50 text-on-background leading-relaxed">
                    {opt.sub}
                  </p>
                </div>
              </label>
            ))
          }
        </div>
      </fieldset>

      <!-- ── Q2: What's the #1 goal ──────────────────────────────── -->
      <fieldset
        class="question-block text-on-surface-variant pointer-events-none transition-all duration-500"
        data-question="2"
      >
        <legend class="sr-only"
          >2. What's the most important thing your website should do? Pick one.
          This shapes which sections matter most for you.</legend
        >
        <div class="flex items-start gap-4 mb-6">
          <div
            class="w-10 h-10 bg-on-background dark:bg-white text-white dark:text-on-background flex items-center justify-center font-black text-lg shrink-0 mt-1"
          >
            2
          </div>
          <div>
            <h2
              class="text-2xl md:text-3xl font-black font-headline uppercase tracking-tighter text-on-background leading-tight"
            >
              What's the most important thing your website should do?
            </h2>
            <p class="text-sm font-medium opacity-60 text-on-background mt-1">
              Pick one. This shapes which sections matter most for you.
            </p>
          </div>
        </div>

        <div class="space-y-3 pl-14" id="q2-options">
          {
            [
              {
                value: "get-calls",
                icon: "phone_in_talk",
                label: "Get more phone calls and WhatsApp messages",
                sub: "I want people to reach me directly — fast.",
              },
              {
                value: "take-bookings",
                icon: "event_available",
                label: "Let customers book or enquire online",
                sub: "I want a form, a booking system, or a WhatsApp flow.",
              },
              {
                value: "show-work",
                icon: "photo_library",
                label: "Show what I do — my work, menu or products",
                sub: "I want people to see what I offer before they contact me.",
              },
              {
                value: "build-trust",
                icon: "verified",
                label: "Look professional and build trust",
                sub: "I want a site that makes people confident to choose me.",
              },
              {
                value: "be-found",
                icon: "search",
                label: "Be found on Google",
                sub: "I want new customers to find me when they search.",
              },
            ].map((opt) => (
              <label class="q2-option group relative flex items-start gap-4 p-5 bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white cursor-pointer hard-shadow-sm hover:-translate-y-0.5 hover:-translate-x-0.5 transition-all has-[:checked]:border-secondary-container has-[:checked]:bg-secondary-container/10">
                <input
                  type="radio"
                  name="primary-goal"
                  value={opt.value}
                  class="sr-only"
                />
                <div class="w-8 h-8 border-[3px] border-on-background dark:border-white flex-shrink-0 flex items-center justify-center group-has-[:checked]:bg-secondary-container transition-colors mt-0.5">
                  <span
                    class="material-symbols-outlined text-sm text-on-background hidden group-has-[:checked]:block"
                    style="font-variation-settings: 'wght' 900;"
                  >
                    check
                  </span>
                </div>
                <div class="flex-grow">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-xl text-on-surface-variant group-has-[:checked]:opacity-100 text-on-background transition-opacity shrink-0">
                      {opt.icon}
                    </span>
                    <span class="font-headline font-black text-base uppercase tracking-tight text-on-background block leading-tight">
                      {opt.label}
                    </span>
                  </div>
                  <p class="text-xs font-medium opacity-50 text-on-background leading-relaxed">
                    {opt.sub}
                  </p>
                </div>
              </label>
            ))
          }
        </div>
      </fieldset>

      <!-- ── Q3: Do you already have assets ─────────────────────── -->
      <fieldset
        class="question-block text-on-surface-variant pointer-events-none transition-all duration-500"
        data-question="3"
      >
        <legend class="sr-only"
          >3. What do you already have? Tick everything that applies. This tells
          us where we can start immediately.</legend
        >

        <legend class="sr-only"
          >3. What do you already have? Tick everything that applies. This tells
          us where we can start immediately.</legend
        >
        <div class="flex items-start gap-4 mb-6">
          <div
            class="w-10 h-10 bg-on-background dark:bg-white text-white dark:text-on-background flex items-center justify-center font-black text-lg shrink-0 mt-1"
          >
            3
          </div>
          <div>
            <h2
              class="text-2xl md:text-3xl font-black font-headline uppercase tracking-tighter text-on-background leading-tight"
            >
              What do you already have?
            </h2>
            <p class="text-sm font-medium opacity-60 text-on-background mt-1">
              Tick everything that applies. This tells us where we can start
              immediately.
            </p>
          </div>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-4 pl-14"
          id="q3-options"
        >
          {
            [
              {
                value: "has-logo",
                icon: "logo_dev",
                label: "A logo",
                sub: "A file or image you use on your business materials.",
              },
              {
                value: "has-photos",
                icon: "camera_alt",
                label: "Photos of your business",
                sub: "Real photos of your work, products, premises or team.",
              },
              {
                value: "has-domain",
                icon: "language",
                label: "A domain name",
                sub: "A web address you own — like mybusiness.com.",
              },
              {
                value: "has-copy",
                icon: "description",
                label: "Written content",
                sub: "Text you're happy to use — about you, your services, etc.",
              },
              {
                value: "has-reviews",
                icon: "reviews",
                label: "Customer reviews",
                sub: "Google, Facebook or written testimonials from real customers.",
              },
              {
                value: "has-nothing",
                icon: "check_box_outline_blank",
                label: "Starting from scratch",
                sub: "That's absolutely fine — we can help with all of it.",
              },
            ].map((opt) => (
              <label class="q3-option group relative flex items-start gap-4 p-5 bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white cursor-pointer hard-shadow-sm hover:-translate-y-1 hover:-translate-x-1 transition-all has-[:checked]:border-secondary-container has-[:checked]:bg-secondary-container/10">
                <input
                  type="checkbox"
                  name="assets"
                  value={opt.value}
                  class="sr-only"
                />
                <div class="w-8 h-8 border-[3px] border-on-background dark:border-white flex-shrink-0 flex items-center justify-center group-has-[:checked]:bg-secondary-container transition-colors mt-0.5">
                  <span
                    class="material-symbols-outlined text-sm text-on-background hidden group-has-[:checked]:block"
                    style="font-variation-settings: 'wght' 900;"
                  >
                    check
                  </span>
                </div>
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-lg text-on-surface-variant group-has-[:checked]:opacity-100  transition-opacity">
                      {opt.icon}
                    </span>
                    <span class="font-headline font-black text-sm uppercase tracking-tight text-on-background">
                      {opt.label}
                    </span>
                  </div>
                  <p class="text-xs font-medium opacity-50 text-on-background leading-relaxed">
                    {opt.sub}
                  </p>
                </div>
              </label>
            ))
          }
        </div>
      </fieldset>

      <!-- ── Q4: Timeline ────────────────────────────────────────── -->
      <fieldset
        class="question-block text-on-surface-variant pointer-events-none transition-all duration-500"
        data-question="4"
      >
        <legend class="sr-only"
          >4. When would you like to go live? No pressure either way — this
          helps us plan the build.</legend
        >
        <div class="flex items-start gap-4 mb-6">
          <div
            class="w-10 h-10 bg-on-background dark:bg-white text-white dark:text-on-background flex items-center justify-center font-black text-lg shrink-0 mt-1"
          >
            4
          </div>
          <div>
            <h2
              class="text-2xl md:text-3xl font-black font-headline uppercase tracking-tighter text-on-background leading-tight"
            >
              When would you like to go live?
            </h2>
            <p class="text-sm font-medium opacity-60 text-on-background mt-1">
              No pressure either way — this helps us plan the build.
            </p>
          </div>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-4 pl-14"
          id="q4-options"
        >
          {
            [
              {
                value: "asap",
                icon: "rocket_launch",
                label: "As soon as possible",
                sub: "I need this up within the next 2–4 weeks.",
              },
              {
                value: "one-month",
                icon: "schedule",
                label: "Within the next month",
                sub: "Roughly 4–6 weeks works for me.",
              },
              {
                value: "two-months",
                icon: "event",
                label: "One to two months",
                sub: "I have a bit of time — I want it done right.",
              },
              {
                value: "no-rush",
                icon: "hourglass_empty",
                label: "No firm deadline yet",
                sub: "I'm planning ahead and want to know the costs first.",
              },
            ].map((opt) => (
              <label class="q4-option group relative flex items-start gap-4 p-5 bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white cursor-pointer hard-shadow-sm hover:-translate-y-1 hover:-translate-x-1 transition-all has-checked:border-secondary-container has-[:checked]:bg-secondary-container/10">
                <input
                  type="radio"
                  name="timeline"
                  value={opt.value}
                  class="sr-only"
                />
                <div class="w-8 h-8 border-[3px] border-on-background dark:border-white shrink-0 flex items-center justify-center group-has-[:checked]:bg-secondary-container transition-colors mt-0.5">
                  <span
                    class="material-symbols-outlined text-sm text-on-background hidden group-has-"
                    style="font-variation-settings: 'wght' 900;"
                  >
                    check
                  </span>
                </div>
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-lg text-on-surface-variant group-has-checked:opacity-100 transition-opacity">
                      {opt.icon}
                    </span>
                    <span class="font-headline font-black text-sm uppercase tracking-tight text-on-background">
                      {opt.label}
                    </span>
                  </div>
                  <p class="text-xs font-medium opacity-50 text-on-background leading-relaxed">
                    {opt.sub}
                  </p>
                </div>
              </label>
            ))
          }
        </div>
      </fieldset>
    </div>

    <!-- ── Recommendation reveal ───────────────────────────────────── -->
    <div id="recommendation" class="hidden mt-20">
      <div
        class="p-10 bg-on-background text-white border-[3px] border-on-background relative overflow-hidden hard-shadow"
      >
        <div
          class="grainy-overlay absolute inset-0 opacity-10 pointer-events-none"
        >
        </div>
        <div class="relative z-10">
          <!-- Header -->
          <div class="flex items-start justify-between gap-6 mb-8">
            <div>
              <div
                class="inline-block bg-secondary-container text-on-background text-[10px] font-black uppercase tracking-widest px-3 py-1 mb-3"
              >
                Based on your answers
              </div>
              <h3
                class="text-3xl md:text-4xl font-black font-headline uppercase tracking-tighter leading-tight"
              >
                Here's what we'd<br />recommend for you
              </h3>
            </div>
            <span
              class="material-symbols-outlined text-5xl text-secondary-container shrink-0"
              >auto_awesome</span
            >
          </div>

          <!-- What we understood -->
          <div
            class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8"
            id="profile-summary"
          >
            <!-- Populated by JS -->
          </div>

          <!-- Recommended blocks preview -->
          <div class="border-t border-white/10 pt-8 mb-8">
            <p
              class="text-[10px] font-black uppercase tracking-widest opacity-50 mb-4"
            >
              Your recommended starting point includes
            </p>
            <div id="rec-blocks-preview" class="flex flex-wrap gap-2">
              <!-- Populated by JS -->
            </div>
          </div>

          <!-- Important note -->
          <div class="bg-white/5 border border-white/10 p-4 mb-8">
            <p class="text-sm font-medium opacity-70 leading-relaxed">
              <span class="text-secondary-container font-black"
                >This is a starting point, not a final decision.</span
              >
              On the next screen you'll see every available element — tick, untick
              and adjust until it's exactly right for your business. Nothing is locked
              in until you say so.
            </p>
          </div>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-4">
            <button
              id="go-to-configurator"
              class="grow py-6 px-8 bg-secondary-container text-on-background font-headline font-black text-xl uppercase tracking-widest border-[3px] border-white shadow-[6px_6px_0px_0px_rgba(255,255,255,1)] hover:-translate-x-0.75 hover:-translate-y-0.75 transition-all flex items-center justify-between group"
            >
              <span>See my recommended build</span>
              <span
                class="material-symbols-outlined text-2xl group-hover:translate-x-1 transition-transform"
                >arrow_forward</span
              >
            </button>
            <button
              id="start-from-scratch"
              class="py-6 px-8 bg-transparent text-white font-headline font-black text-sm uppercase tracking-widest border-2 border-white/30 hover:border-white/60 transition-colors"
            >
              I'd rather start with a blank slate
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer hideOnMobile={true} />
</Layout>

<script>
  import { selectedBlockIds, profileData } from "../store/cart";
  import {
    BUSINESS_LABELS,
    GOAL_LABELS,
    TIMELINE_LABELS,
  } from "../data/labels";

  // ── Configuration Data ────────────────────────────────────────────────
  const recommendations: Record<string, string[]> = {
    "local-service": [
      "responsive-layout",
      "ssg-engine",
      "responsive-navbar",
      "hero-section",
      "trust-badges",
      "pricing-table",
      "services-reservation",
      "service-highlights",
      "faq-accordion",
      "contact-form-alt",
      "location-maps",
      "footer-complex",
      "sticky-mobile-cta",
      "whatsapp-strategy",
    ],
    "restaurant-cafe": [
      "responsive-layout",
      "ssg-engine",
      "responsive-navbar",
      "hero-section",
      "trust-badges",
      "fleet-showcase",
      "google-reviews",
      "faq-accordion",
      "contact-form-alt",
      "location-maps",
      "footer-complex",
      "sticky-mobile-cta",
    ],
    "retail-ecommerce": [
      "responsive-layout",
      "ssg-engine",
      "responsive-navbar",
      "hero-section",
      "trust-badges",
      "fleet-showcase",
