  {
    name: "Classic Corporate",
    primary: "#0A5C8E",
    bg: "#eff4f8",
    shades: [
      "#0A3E5F",
      "#0F4F71",
      "#16648B",
      "#1C6D98",
      "#0A5C8E",
      "#3978A6",
      "#7EA8C5",
      "#B7D7E9",
      "#DEF0FB",
      "#FFFFFF",
    ],
    description:
      "Professional, secure, and established. Ideal for finance, law, and corporate services.",
  },
  {
    name: "Modern SaaS",
    primary: "#635BFF",
    bg: "#f5f5ff",
    shades: [
      "#1110A1",
      "#2B24CE",
      "#4538E2",
      "#5246F4",
      "#635BFF",
      "#8A80FF",
      "#B1AFFF",
      "#D4D1FF",
      "#EEEDFF",
      "#FFFFFF",
    ],
    description:
      "Clean, minimal, and performance-focused. Best for tech, productivity tools, and software.",
  },
  {
    name: "Warm & Trustworthy",
    primary: "#1E6F5C",
    bg: "#eef8f5",
    shades: [
      "#124339",
      "#1F5D4B",
      "#2B7A60",
      "#3F8E71",
      "#1E6F5C",
      "#69AB8B",
      "#9DCDAE",
      "#CFE7D8",
      "#EDF8F0",
      "#FFFFFF",
    ],
    description:
      "Ethical, organic, and stable. Suited for healthcare, education, and social ventures.",
  },
  {
    name: "Dark Mode Ready",
    primary: "#7C3AED",
    bg: "#f4f2ff",
    shades: [
      "#4317A0",
      "#5C24C4",
      "#6C2CD8",
      "#7C3AED",
      "#8C59EF",
      "#9F77F3",
      "#B79CEF",
      "#D2CAFF",
      "#ECE7FF",
      "#FFFFFF",
    ],
    description:
      "High-energy and digital-first. Optimized for high-contrast dark UI environments.",
  },
  {
    name: "E-Commerce Optimized",
    primary: "#1C4E80",
    bg: "#eff3f6",
    shades: [
      "#122F4A",
      "#173E5A",
      "#1D4A68",
      "#1F5575",
      "#1C4E80",
      "#406896",
      "#7693B4",
      "#B8CBE3",
      "#E3EAF2",
      "#FFFFFF",
    ],
    description:
      "Conversion-centric. Designed to build buyer confidence and drive purchase actions.",
  },
  {
    name: "Minimal & Luxe",
    primary: "#000000",
    bg: "#ededed",
    shades: [
      "#000000",
      "#1A1A1A",
      "#303030",
      "#4A4A4A",
      "#666666",
      "#8F8F8F",
      "#B6B6B6",
      "#DBDBDB",
      "#F5F5F0",
      "#FFFFFF",
    ],
    description:
      "Sophisticated, distinctive, and timeless. Common in luxury fashion and high-end design.",
  },
  {
    name: "Accessible First",
    primary: "#005F73",
    bg: "#eaf4f5",
    shades: [
      "#003a4b",
      "#004f61",
      "#005f73",
      "#2a867f",
      "#0A9396",
      "#2bb5b8",
      "#67d5d9",
      "#a6eaed",
      "#dbf7f8",
      "#FFFFFF",
    ],
    description:
      "Maximum inclusion. Curated to meet WCAG AAA standards across all combinations.",
  },
  {
    name: "Creative & Bold",
    primary: "#FF6B6B",
    bg: "#fff5f7",
    shades: [
      "#a9000d",
      "#bf1a34",
      "#dc3549",
      "#f1555f",
      "#FF6B6B",
      "#ff8f8f",
      "#ffb7b7",
      "#ffdada",
      "#ffeeee",
      "#FFFFFF",
    ],
    description:
      "Energetic and attention-grabbing. Ideal for agencies, portfolios, and creative startups.",
  },
  {
    name: "High Readability",
    primary: "#003366",
    bg: "#f4f8ff",
    shades: [
      "#001f35",
      "#002b4d",
      "#003366",
      "#17467d",
      "#285e8f",
      "#4a7bb2",
      "#7aa0cc",
      "#b2c8ed",
      "#deebfb",
      "#FFFFFF",
    ],
    description:
      "Regulatory grade. Focused on content clarity and informational integrity.",
  },
  {
    name: "Nature & Sustainable",
    primary: "#2F5D3A",
    bg: "#f7f5ef",
    shades: [
      "#1a371f",
      "#264a2c",
      "#2f5d3a",
      "#4e7b56",
      "#7da98a",
      "#b0cdb6",
      "#d8e6d8",
      "#edf5ef",
      "#fafcf8",
      "#FFFFFF",
    ],
    description:
      "Calm, grounded, and eco-centric. Suited for wellness and sustainability brands.",
  },
];
---

<Layout>
  <div class="fixed inset-0 grainy-overlay z-50 pointer-events-none opacity-5">
  </div>
  <Header showDropdown={false} />

  <main
    id="main-content"
    class="pt-32 pb-32 px-4 md:px-12 max-w-7xl mx-auto text-on-background"
  >
    <!-- Hero Title -->
    <section class="mb-20 relative">
      <div class="relative inline-block">
        <h1
          class="text-6xl md:text-8xl font-black font-headline uppercase leading-[0.85] tracking-tighter relative z-10"
        >
          Colour<br /><span class="text-primary-container">Library</span>
        </h1>
        <div
          class="absolute -right-4 bottom-2 bg-secondary-container w-full h-1/2 -z-0"
        >
        </div>
      </div>
      <p
        class="mt-8 text-xl font-bold max-w-2xl opacity-80 uppercase tracking-tight"
      >
        10 curated industrial-grade palettes. Each configuration is optimized
        for accessibility, contrast, and professional impact.
      </p>
    </section>

    <!-- Palette Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        palettes.map((palette) => (
          <article class="bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white hard-shadow hover:-translate-y-1 transition-all overflow-hidden flex flex-col">
            <div
              class="h-32 p-6 flex flex-col justify-between text-white"
              style={`background-color: ${palette.primary}`}
            >
              <div class="flex justify-between items-start">
                <h2 class="font-headline font-black uppercase text-xl tracking-tighter leading-none">
                  {palette.name}
                </h2>
                <span class="font-mono text-xs font-bold bg-black/20 px-2 py-1 uppercase">
                  {palette.primary}
                </span>
              </div>
              <p class="text-[10px] font-black uppercase tracking-widest opacity-80">
                Primary Directive
              </p>
            </div>

            <div class="p-6 flex-grow flex flex-col">
              <p class="font-body text-xs font-medium uppercase leading-relaxed opacity-70 mb-8 dark:text-white/70">
                {palette.description}
              </p>

              <div class="mt-auto">
                <div class="grid grid-cols-10 gap-1 mb-4">
                  {palette.shades.map((shade) => (
                    <div
                      class="h-10 border border-on-background/5"
                      style={`background-color: ${shade}`}
                      title={shade}
                    />
                  ))}
                </div>
                <div class="flex justify-between text-[8px] font-black uppercase text-on-surface-variant dark:text-white/40 tracking-tighter">
                  <span>Deep Shade</span>
                  <span>Standard Base</span>
                  <span>Pure White</span>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </section>

    <!-- Hierarchy Protocol -->
    <section class="mt-32">
      <h2
        class="text-4xl font-black font-headline uppercase tracking-tighter mb-10"
      >
        Hierarchy Protocol
      </h2>
      <div
        class="bg-on-background dark:bg-white text-white dark:text-on-background p-10 border-[3px] border-on-background dark:border-white hard-shadow"
      >
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
          <div class="space-y-4">
            <span class="text-primary-container font-black text-4xl">80%</span>
            <h3
              class="font-headline font-black uppercase text-lg tracking-widest"
            >
              Primary Directive
            </h3>
            <p class="text-xs uppercase font-bold opacity-60 leading-relaxed">
              Dominates the visual space. Used for layouts, neutral backgrounds,
              and core components.
            </p>
          </div>
          <div class="space-y-4">
            <span class="text-secondary-container font-black text-4xl">15%</span
            >
            <h3
              class="font-headline font-black uppercase text-lg tracking-widest"
            >
              Secondary Layer
            </h3>
            <p class="text-xs uppercase font-bold opacity-60 leading-relaxed">
              Used for buttons, calls to action, and interactive surface states.
            </p>
          </div>
          <div class="space-y-4">
            <span class="text-primary-container font-black text-4xl">05%</span>
            <h3
              class="font-headline font-black uppercase text-lg tracking-widest"
            >
              Accent Surge
            </h3>
            <p class="text-xs uppercase font-bold opacity-60 leading-relaxed">
              High-impact highlights, status indicators, and critical data
              points.
            </p>
          </div>
          <div class="space-y-4">
            <span
              class="text-white dark:text-on-background font-black text-4xl italic"
              >WCAG</span
            >
            <h3
              class="font-headline font-black uppercase text-lg tracking-widest"
            >
              Compliance
            </h3>
            <p class="text-xs uppercase font-bold opacity-60 leading-relaxed">
              All configurations are audited for a minimum 4.5:1 contrast ratio
              for data legibility.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer variant="traditional" />
</Layout>
