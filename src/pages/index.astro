---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="fixed inset-0 grainy-overlay z-[-1]"></div>
  <Header />

  <main id="main-content" class="relative pt-18">
    <!-- Hero -->
    <section
      class="min-h-[calc(100svh-6rem)] flex flex-col items-center justify-center px-6 lg:px-24 py-12 relative overflow-hidden"
    >
      <div
        class="hidden sm:block absolute top-20 right-10 w-64 h-64 bg-secondary-container/20 border-[3px] border-on-background dark:border-white -rotate-12 -z-10"
      >
      </div>
      <div
        class="hidden sm:block absolute bottom-40 left-10 w-48 h-48 bg-primary-container/10 border-[3px] border-on-background dark:border-white rotate-45 -z-10"
      >
      </div>

      <div
        class="max-w-7xl w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-center"
      >
        <div class="z-10 order-2 lg:order-1">
          <h1
            class="font-headline font-black text-6xl md:text-8xl lg:text-9xl leading-[0.9] uppercase tracking-tighter mb-8 text-on-background"
          >
            YOUR WEBSITE. <span class="text-primary-container"
              >YOUR CHOICE.</span
            > YOUR PRICE.
          </h1>
          <p
            class="font-body text-xl md:text-2xl text-on-surface-variant dark:text-white/80 max-w-xl mb-6 border-l-[6px] border-secondary-container pl-6 leading-relaxed"
          >
            We've broken every part of a website into plain English. You pick
            what your business needs. We build it. No hidden fees. No guesswork.
          </p>
          <p
            class="font-body text-base text-on-surface-variant dark:text-white/60 max-w-xl mb-12 pl-6 opacity-60"
          >
            Four quick questions first — then we suggest the right starting
            point for you.
          </p>
          <a
            href="/start"
            class="bg-secondary-container text-on-background border-[3px] border-on-background dark:border-white px-10 py-6 text-xl font-headline font-black uppercase tracking-widest hard-shadow hover:-translate-y-1 hover:-translate-x-1 transition-transform active:translate-x-0 active:translate-y-0 active:shadow-none inline-flex items-center gap-3"
          >
            CONFIGURE YOUR SITE
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <p
            class="text-xs font-bold uppercase text-on-surface-variant mt-4 pl-1"
          >
            No account needed · No obligation · Takes 2 minutes
          </p>
        </div>

        <div
          class="relative flex justify-center items-center order-1 lg:order-2"
        >
          <div class="relative w-full aspect-square max-w-125">
            <div
              class="absolute inset-0 bg-primary-container/5 backdrop-blur-xl border-[3px] border-on-background dark:border-white translate-x-4 translate-y-4"
            >
            </div>
            <img
              alt="Abstract building blocks representing website elements"
              class="w-full h-full object-cover border-[3px] border-on-background dark:border-white grayscale contrast-125 mix-blend-multiply dark:mix-blend-screen relative z-10 shadow-2xl"
              src="/images/hero-blocks.webp"
              width="500"
              height="500"
              loading="eager"
              fetchpriority="high"
            />
            <div
              class="absolute -top-3 -right-10 bg-secondary-container text-on-background border-[3px] border-on-background dark:border-white p-4 z-20 hard-shadow-sm font-label text-xs uppercase font-bold max-w-40 text-center leading-tight"
            >
              YOUR QUOTE IS FREE — NO OBLIGATION
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works — 3 steps -->
    <section class="py-24 px-4 md:px-12 max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          [
            {
              num: "01",
              icon: "quiz",
              title: "Tell us about your business",
              body: "Four plain-English questions. No jargon, no technical knowledge needed. Takes about two minutes.",
              color: "bg-surface dark:bg-on-background dark:text-white",
            },
            {
              num: "02",
              icon: "checklist",
              title: "Pick what you need",
              body: "We suggest a starting point based on your answers. Tick, untick and adjust until it's right. Your price updates as you go.",
              color: "bg-secondary-container text-on-background",
            },
            {
              num: "03",
              icon: "picture_as_pdf",
              title: "Get a free quote — instantly",
              body: "A detailed proposal is generated for you to keep. No cost, no obligation to proceed.",
              color:
                "bg-on-background dark:bg-white text-white dark:text-on-background",
            },
          ].map((step) => (
            <div
              class={`${step.color} border-[3px] border-on-background dark:border-white p-8 hard-shadow flex flex-col`}
            >
              <div class="flex justify-between items-start mb-10">
                <span class="font-mono text-xs font-bold opacity-30 uppercase tracking-widest">
                  {step.num}
                </span>
                <span
                  class={`material-symbols-outlined text-3xl ${step.color.includes("on-background") && !step.color.includes("dark:bg-white") ? "text-secondary-container" : "text-on-surface-variant"}`}
                >
                  {step.icon}
                </span>
              </div>
              <h3 class="font-headline font-black text-2xl uppercase tracking-tighter mb-4 leading-tight">
                {step.title}
              </h3>
              <p class={`text-sm font-medium leading-relaxed opacity-70`}>
                {step.body}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- STARTER BLUEPRINTS (PRESETS) -->
    <section class="py-32 px-4 md:px-12 max-w-7xl mx-auto">
      <div class="mb-20 text-center">
        <h2
          class="text-5xl md:text-7xl font-black font-headline uppercase tracking-tighter mb-6"
        >
          STARTER BLUEPRINTS
        </h2>
        <p class="text-xl font-bold uppercase opacity-60 max-w-2xl mx-auto">
          Pre-configured architectural foundations. Select a baseline and
          customize to your specifications.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Preset 1: The Creative Portfolio -->
        <div
          class="bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white hard-shadow p-8 flex flex-col hover:-translate-y-2 transition-all group"
        >
          <div class="flex justify-between items-start mb-8">
            <div
              class="w-12 h-12 bg-primary-container text-white flex items-center justify-center font-black"
            >
              P1
            </div>
            <span class="font-mono text-sm font-bold text-on-surface-variant"
              >EST. €1,180</span
            >
          </div>
          <h3
            class="text-3xl font-black font-headline uppercase mb-4 tracking-tight"
          >
            The Portfolio
          </h3>
          <p class="text-sm font-medium opacity-70 uppercase mb-8 grow">
            For creatives and anyone whose work should speak for itself
          </p>
          <button
            class="preset-btn w-full bg-on-background dark:bg-white text-white dark:text-on-background py-4 font-headline font-black uppercase tracking-widest hover:bg-secondary-container hover:text-on-background transition-colors"
            data-blocks="responsive-layout,portfolio-grid,seo-supremacy"
          >
            SELECT & CONFIGURE
          </button>
        </div>

        <!-- Preset 2: The Content Engine -->
        <div
          class="bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white hard-shadow p-8 flex flex-col hover:-translate-y-2 transition-all group"
        >
          <div class="flex justify-between items-start mb-8">
            <div
              class="w-12 h-12 bg-secondary-container text-on-background flex items-center justify-center font-black"
            >
              P2
            </div>
            <span class="font-mono text-sm font-bold text-on-surface-variant"
              >EST. €1,020</span
            >
          </div>
          <h3
            class="text-3xl font-black font-headline uppercase mb-4 tracking-tight"
          >
            Business Engine
          </h3>
          <p class="text-sm font-medium opacity-70 uppercase mb-8 grow">
            For service businesses who need to be found, contacted, and trusted
          </p>
          <button
            class="preset-btn w-full bg-on-background dark:bg-white text-white dark:text-on-background py-4 font-headline font-black uppercase tracking-widest hover:bg-secondary-container hover:text-on-background transition-colors"
            data-blocks="ssg-engine,blog-engine,contact-form,google-reviews"
          >
            SELECT & CONFIGURE
          </button>
        </div>

        <!-- Preset 3: The Full Conversion Suite -->
        <div
          class="bg-on-background dark:bg-white text-white dark:text-on-background border-[3px] border-on-background dark:border-white hard-shadow p-8 flex flex-col hover:-translate-y-2 transition-all group"
        >
          <div class="flex justify-between items-start mb-8">
            <div
              class="w-12 h-12 bg-white dark:bg-on-background text-on-background dark:text-white flex items-center justify-center font-black"
            >
              P3
            </div>
            <span
              class="font-mono text-sm font-bold text-on-surface-variant dark:text-on-background/40"
              >EST. €2,200+</span
            >
          </div>
          <h3
            class="text-3xl font-black font-headline uppercase mb-4 tracking-tight"
          >
            Full Alpha
          </h3>
          <p class="text-sm font-medium opacity-70 uppercase mb-8 grow">
            Everything — for businesses ready to go all-in online
          </p>
          <button
            class="preset-btn w-full bg-secondary-container text-on-background py-4 font-headline font-black uppercase tracking-widest hover:bg-white transition-colors"
            data-blocks="responsive-layout,ai-personalization,whatsapp-strategy,hero-section,pricing-table,performance-optimization"
          >
            SELECT & CONFIGURE
          </button>
        </div>
      </div>
    </section>

    <!-- Bento Blueprint Section (Restored) -->
    <section
      class="bg-surface-container dark:bg-on-background/10 border-y-[3px] border-on-background dark:border-white py-24 px-8"
    >
      <div class="max-w-7xl mx-auto">
        <div class="mb-16">
          <span
            class="bg-tertiary-fixed text-on-tertiary-fixed border-2 border-on-background dark:border-white px-3 py-1 font-label text-xs font-bold uppercase"
            >System Overview</span
          >
          <h2
            class="font-headline font-black text-5xl uppercase mt-4 tracking-tighter"
          >
            THE BUILDING BLOCKS
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-6">
          <!-- Bento Box 1 -->
          <a
            href="/start"
            class="md:col-span-2 lg:col-span-3 bg-surface-container-lowest dark:bg-on-background border-[3px] border-on-background dark:border-white p-8 flex flex-col justify-between hover:bg-secondary-container transition-colors group"
          >
            <div class="flex justify-between items-start mb-12">
              <span class="material-symbols-outlined text-4xl">grid_view</span>
              <span class="font-label text-sm font-bold text-on-surface-variant"
                >01 / 04</span
              >
            </div>
            <div>
              <h3 class="font-headline font-bold text-3xl uppercase mb-2">
                DYNAMIC LAYOUTS
              </h3>
              <p class="font-body text-sm opacity-70">
                Structural foundations built for scalability and performance.
              </p>
            </div>
          </a>
          <!-- Bento Box 2 -->
          <div
            class="md:col-span-2 lg:col-span-3 bg-primary-container text-white border-[3px] border-on-background dark:border-white p-8 relative overflow-hidden"
          >
            <div
              class="absolute top-0 right-0 p-4 font-label text-[100px] leading-none opacity-20 font-black"
            >
              72%
            </div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <span class="material-symbols-outlined text-4xl">speed</span>
              <div>
                <h3 class="font-headline font-bold text-3xl uppercase mb-2">
                  FASTER DELIVERY
                </h3>
                <p class="font-body text-sm opacity-80">
                  Component-based assembly reduces traditional dev cycles by
                  weeks.
                </p>
              </div>
            </div>
          </div>
          <!-- Bento Box 3 -->
          <div
            class="md:col-span-4 lg:col-span-2 bg-surface-container-highest dark:bg-on-background border-[3px] border-on-background dark:border-white p-8 hover:bg-surface dark:hover:bg-on-background/80 transition-colors"
          >
            <div class="flex flex-col h-full justify-between">
              <div class="mb-8">
                <span class="material-symbols-outlined text-4xl mb-4"
                  >currency_exchange</span
                >
                <h3 class="font-headline font-bold text-3xl uppercase mb-2">
                  FIXED PRICING
                </h3>
              </div>
              <div class="text-lg font-bold">You see every line</div>
              <div
                class="border-t-[3px] border-on-background dark:border-white pt-4"
              >
                <span class="font-label font-bold text-2xl"
                  >Prices from €18 to €450</span
                >
              </div>
            </div>
          </div>
          <!-- Bento Box 4 -->
          <div
            class="md:col-span-4 lg:col-span-4 bg-surface-container-lowest dark:bg-on-background border-[3px] border-on-background dark:border-white p-8 grid grid-cols-1 sm:grid-cols-2 gap-8 items-center"
          >
            <div>
              <h3
                class="font-headline font-bold text-4xl uppercase mb-4 tracking-tighter"
              >
                AUTHENTIC TRANSPARENCY
              </h3>
              <p class="font-body text-base mb-6 opacity-70">
                Every line of code is accounted for. Every component is priced
                fairly. No agency markup, just architectural excellence.
              </p>
              <a
                class="inline-flex items-center gap-2 font-headline font-bold uppercase text-sm border-b-[3px] border-primary-container pb-1 hover:text-primary-container transition-colors"
                href="/catalog"
              >
                View Component Catalog <span class="material-symbols-outlined"
                  >arrow_forward</span
                >
              </a>
            </div>
            <div class="h-48 bg-on-background relative overflow-hidden">
              <img
                alt="Technical circuit layout"
                class="w-full h-full object-cover opacity-50 grayscale contrast-150"
                src="/images/circuit-layout.webp"
              />
              <div class="absolute inset-0 flex items-center justify-center">
                <div
                  class="bg-secondary-container text-on-background px-4 py-2 font-label font-bold text-xs uppercase -rotate-12 border-2 border-on-background dark:border-white"
                >
                  NOTHING HIDDEN
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Social Proof / Verified Builds ────────────────────────── -->
    <section
      class="py-24 border-t-[3px] border-on-background dark:border-white bg-surface-container-lowest relative overflow-hidden"
    >
      <div
        class="grainy-overlay absolute inset-0 opacity-5 pointer-events-none"
      >
      </div>

      <!-- Industry Trust Bar -->
      <div class="max-w-7xl mx-auto px-8 mb-20">
        <p
          class="text-center font-label text-[10px] uppercase font-black tracking-[0.3em] opacity-30 mb-8"
        >
          System Compatibility & Verified Tech
        </p>
        <div
          class="flex flex-wrap items-center justify-center gap-8 md:gap-20 opacity-20 grayscale contrast-200"
        >
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-3xl">verified_user</span
            >
            <span
              class="font-headline font-black text-2xl tracking-tighter italic"
              >Built with Astro</span
            >
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-3xl">payments</span>
            <span
              class="font-headline font-black text-2xl tracking-tighter italic"
              >Cloudflare Hosted</span
            >
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-3xl">rocket_launch</span
            >
            <span
              class="font-headline font-black text-2xl tracking-tighter italic"
              >Blazing Fast Speed</span
            >
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Testimonial 1 -->
          <div
            class="bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white p-8 hard-shadow-sm flex flex-col justify-between"
          >
            <div class="mb-8">
              <div class="flex gap-1 text-secondary-container mb-4">
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
              </div>
              <p
                class="font-body font-bold text-lg leading-tight text-on-background"
              >
                "Finally, a developer who speaks human. The quote I got in the
                configurator was exactly what I paid. No surprises."
              </p>
            </div>
            <div>
              <p
                class="font-headline font-black text-xs uppercase tracking-widest text-primary-container"
              >
                Sarah Jenkins
              </p>
              <p
                class="font-label text-[10px] uppercase text-on-surface-variant"
              >
                Founder, Bloom & Wild Florals
              </p>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div
            class="bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white p-8 hard-shadow-sm flex flex-col justify-between transform md:translate-y-4"
          >
            <div class="mb-8">
              <div class="flex gap-1 text-secondary-container mb-4">
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
              </div>
              <p
                class="font-body font-bold text-lg leading-tight text-on-background"
              >
                "The build was lightning fast. Our site loads instantly on
                mobile, and our Google ranking has already started to climb."
              </p>
            </div>
            <div>
              <p
                class="font-headline font-black text-xs uppercase tracking-widest text-primary-container"
              >
                Marcus Thorne
              </p>
              <p
                class="font-label text-[10px] uppercase text-on-surface-variant"
              >
                Director, Thorne Logistics
              </p>
            </div>
          </div>

          <!-- Testimonial 3 -->
          <div
            class="bg-surface dark:bg-on-background border-[3px] border-on-background dark:border-white p-8 hard-shadow-sm flex flex-col justify-between"
          >
            <div class="mb-8">
              <div class="flex gap-1 text-secondary-container mb-4">
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
                <span
                  class="material-symbols-outlined text-sm"
                  style="font-variation-settings: 'FILL' 1;">star</span
                >
              </div>
              <p
                class="font-body font-bold text-lg leading-tight text-on-background"
              >
                "I didn't have a clue where to start. The questionnaire
                suggested everything I needed and nothing I didn't. Highly
                recommended."
              </p>
            </div>
            <div>
              <p
                class="font-headline font-black text-xs uppercase tracking-widest text-primary-container"
              >
                Elena Rossi
              </p>
              <p
                class="font-label text-[10px] uppercase text-on-surface-variant"
              >
                Owner, Rossi's Kitchen
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-32 px-6 text-center">
      <h2
        class="font-headline font-black text-5xl md:text-7xl uppercase tracking-tighter mb-6 text-on-background"
      >
        Ready to see what<br />your site would cost?
      </h2>
      <p
        class="text-xl font-bold opacity-60 max-w-xl mx-auto mb-12 text-on-background"
      >
        Start with four questions. Get a detailed quote. Pay nothing until
        you're completely happy with the plan.
      </p>
      <a
        href="/start"
        class="bg-secondary-container text-on-background border-[3px] border-on-background dark:border-white px-12 py-6 text-2xl font-headline font-black uppercase tracking-widest hard-shadow hover:-translate-y-1 hover:-translate-x-1 transition-transform active:translate-x-0 active:translate-y-0 active:shadow-none inline-flex items-center gap-3"
      >
        Start — it's free
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </section>
  </main>

  <Footer variant="traditional" />

  <script>
    import { selectedBlockIds } from "../store/cart";
    const presetBtns = document.querySelectorAll(".preset-btn");
    presetBtns.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const blocks = target.dataset.blocks?.split(",") || [];
        selectedBlockIds.set(blocks);
        window.location.href = "/configurator";
      });
    });
  </script>

  <div class="hidden lg:block fixed bottom-8 right-8 z-60">
    <div
      class="bg-on-background dark:bg-white text-surface dark:text-on-background px-6 py-4 hard-shadow-sm border-2 border-primary-container"
    >
      <p class="font-label text-[10px] uppercase font-black mb-1 opacity-50">
        Our Promise
      </p>
      <p
        class="font-headline font-bold text-sm tracking-widest flex items-center gap-2"
      >
        <span class="w-2 h-2 bg-secondary-container inline-block animate-pulse"
        ></span>
        100% TRANSPARENT PRICING
      </p>
    </div>
  </div>
</Layout>
