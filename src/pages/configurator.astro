---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyBar from "../components/StickyBar.astro";
import { BLOCK_META } from "../store/blockRegistry";
import { BLOCKS } from "../store/cart";

const section01 = [
  BLOCKS["hero-section"],
  BLOCKS["trust-badges"],
  BLOCKS["service-highlights"],
];
const section02 = [
  BLOCKS["fleet-showcase"],
  BLOCKS["pricing-table"],
  BLOCKS["services-reservation"],
  BLOCKS["portfolio-grid"],
];
const section03 = [
  BLOCKS["google-reviews"],
  BLOCKS["faq-accordion"],
  BLOCKS["location-maps"],
  BLOCKS["contact-form"],
  BLOCKS["contact-form-alt"],
];
const section04 = [
  BLOCKS["blog-engine"],
  BLOCKS["ai-personalization"],
  BLOCKS["whatsapp-strategy"],
  BLOCKS["performance-optimization"],
  BLOCKS["sticky-mobile-cta"],
];

const SECTIONS = [
  {
    id: "section-01",
    num: "01",
    name: "First impression",
    desc: "What visitors see and feel in the first 8 seconds.",
    blocks: section01,
  },
  {
    id: "section-02",
    num: "02",
    name: "What you offer",
    desc: "Your products, services and pricing — front and centre.",
    blocks: section02,
  },
  {
    id: "section-03",
    num: "03",
    name: "Build trust",
    desc: "Reviews, answers and contact — close the sale.",
    blocks: section03,
  },
  {
    id: "section-04",
    num: "04",
    name: "Power it up",
    desc: "Advanced tools for businesses ready to go further.",
    blocks: section04,
  },
];

const includedBlocks = [
  BLOCKS["responsive-layout"],
  BLOCKS["ssg-engine"],
  BLOCKS["responsive-navbar"],
  BLOCKS["footer-complex"],
  BLOCKS["seo-supremacy"],
  BLOCKS["brand-system"],
  BLOCKS["discovery-ux"],
];

const getBlockMeta = (id: string) => {
  return (
    BLOCK_META[id as keyof typeof BLOCK_META] || {
      icon: "help",
      label: "Block",
      description: "",
      why: "",
    }
  );
};
---

<Layout>
  <div class="fixed inset-0 grainy-overlay z-50 pointer-events-none opacity-5">
  </div>
  <Header showDropdown={false} />

  <main
    id="main-content"
    class="pt-32 pb-48 px-4 md:px-12 max-w-7xl mx-auto text-on-background"
  >
    <!-- Page header -->
    <section class="mb-20">
      <div class="relative inline-block">
        <h1
          class="text-6xl md:text-8xl font-black font-headline uppercase leading-[0.85] tracking-tighter relative z-10"
        >
          Build Your<br />Website
        </h1>
        <div
          class="absolute -right-4 -bottom-2 bg-secondary-container w-full h-1/2 -z-0"
        >
        </div>
      </div>
      <p class="mt-8 text-lg font-bold max-w-2xl opacity-70 leading-relaxed">
        Tick what you need. Leave out what you don't. Your running total updates
        as you go — and the diagram below tracks every selection in real time.
      </p>
    </section>

    <!-- Sticky section nav -->
    <nav
      class="sticky top-20 md:top-24 z-40 bg-surface/95 dark:bg-on-background/95 backdrop-blur-md border-b-[3px] border-on-background dark:border-white py-3 md:py-4 overflow-hidden mb-12 md:mb-16"
    >
      <div class="relative px-4 md:px-1">
        <div
          id="section-nav-scroll"
          class="flex gap-6 md:gap-10 overflow-x-auto no-scrollbar relative py-1"
        >
          {
            SECTIONS.map((s) => (
              <a
                href={`#${s.id}`}
                class="section-nav-link font-headline font-black text-[10px] md:text-xs uppercase tracking-widest text-on-background/40 dark:text-white/40 hover:text-on-background dark:hover:text-white transition-all shrink-0 pb-1"
              >
                {s.num}. {s.name}
              </a>
            ))
          }
          <a
            href="#section-included"
            class="section-nav-link font-headline font-black text-[10px] md:text-xs uppercase tracking-widest text-on-background/40 dark:text-white/40 hover:text-on-background dark:hover:text-white transition-all shrink-0 pb-1"
          >
            Included
          </a>
          <div
            id="nav-indicator"
            class="absolute bottom-0 h-[3px] bg-primary-container transition-all duration-300 ease-out opacity-0 pointer-events-none"
          >
          </div>
        </div>
      </div>
    </nav>

    <form id="configurator-form">
      <!-- ══════════════════════════════════════════════════════════════
                 PAIRED GRID — left cards + right schematic
                 This wrapper div has id="sections-grid". JS measures its
                 bottom edge and stops the right column sticking at that point.
                 The always-included section and CTA live OUTSIDE this grid.
            ══════════════════════════════════════════════════════════════ -->
      <div
        id="sections-grid"
        class="grid grid-cols-1 lg:grid-cols-12 gap-x-12 items-start"
      >
        <!-- LEFT: four selectable sections only -->
        <div class="lg:col-span-7 space-y-24" id="sections-left">
          {
            SECTIONS.map((section) => (
              <section
                id={section.id}
                class="scroll-mt-40"
                data-section-id={section.id}
              >
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-12 h-12 bg-on-background text-white flex items-center justify-center font-black text-2xl shrink-0">
                    {section.num}
                  </div>
                  <h2 class="text-4xl font-black font-headline uppercase tracking-tighter">
                    {section.name}
                  </h2>
                  <div class="flex-grow h-[3px] bg-on-background hidden md:block" />
                </div>
                <p class="text-sm font-medium opacity-60 mb-10 pl-16 leading-relaxed">
                  {section.desc}
                </p>

                <fieldset class="space-y-4">
                  <legend class="sr-only">
                    Section {section.num}: {section.name}
                  </legend>
                  {section.blocks.map((block) => {
                    const meta = getBlockMeta(block.id);
                    return (
                      <label
                        class="group relative flex items-start gap-5 p-6 bg-surface border-[3px] border-on-background has-[:checked]:border-primary-container has-[:checked]:bg-secondary-container/5 hard-shadow-sm hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_0px_rgba(28,27,27,1)] transition-all cursor-pointer"
                        data-block-id={block.id}
                      >
                        <input
                          class="sr-only block-checkbox"
                          type="checkbox"
                          data-id={block.id}
                        />

                        <div class="w-10 h-10 border-[3px] border-on-background flex-shrink-0 flex items-center justify-center group-has-[:checked]:bg-secondary-container transition-colors mt-0.5">
                          <span
                            class="material-symbols-outlined text-on-background hidden group-has-[:checked]:block"
                            style="font-variation-settings:'wght' 900;"
                          >
                            check
                          </span>
                        </div>

                        <div class="w-9 h-9 flex-shrink-0 flex items-center justify-center mt-0.5">
                          <span class="material-symbols-outlined text-xl opacity-20 group-has-[:checked]:opacity-70 group-has-[:checked]:text-primary-container transition-all">
                            {meta.icon}
                          </span>
                        </div>

                        <div class="flex-grow min-w-0">
                          <div class="flex justify-between items-start gap-4 mb-2">
                            <h3 class="text-lg font-black font-headline uppercase tracking-tighter leading-tight">
                              {meta.label}
                            </h3>
                            <span class="font-mono text-lg font-bold tracking-tight shrink-0 opacity-75">
                              €{block.price}
                            </span>
                          </div>
                          <p class="text-sm font-medium opacity-55 leading-relaxed mb-3">
                            {meta.description}
                          </p>
                          <div class="border-l-[3px] border-primary-container pl-3 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity">
                            <p class="text-xs font-bold text-on-surface-variant leading-relaxed italic">
                              {meta.why}
                            </p>
                          </div>
                        </div>
                      </label>
                    );
                  })}
                </fieldset>
              </section>
            ))
          }
        </div>
        <!-- END LEFT -->

        <!-- RIGHT: schematic — mobile: below cards, desktop: sticky sidebar -->
        <div
          id="schematic-col"
          class="lg:col-span-5 flex flex-col gap-4 mt-16 lg:mt-0"
        >
          <!-- Mobile toggle button (visible only on small screens) -->
          <button
            id="schematic-toggle"
            type="button"
            class="lg:hidden flex items-center justify-between w-full p-4 bg-surface border-[3px] border-on-background hard-shadow-sm font-headline font-black uppercase tracking-wider"
            aria-expanded="false"
          >
            <span>Live Preview</span>
            <span
              class="material-symbols-outlined transition-transform"
              id="toggle-icon">expand_more</span
            >
          </button>

          <!-- Schematic content - collapsible on mobile -->
          <div id="schematic-content" class="hidden lg:block">
            <div
              class="text-[10px] font-black uppercase tracking-[0.25em] text-on-surface-variant text-center mb-2"
            >
              Your page — tracking live
            </div>

            <!-- Panel with aspect ratio -->
            <div
              id="schematic-panel"
              class="border-[3px] border-on-background/20 overflow-hidden bg-white relative w-full"
              style="aspect-ratio: 200 / 200;"
            >
              <div
