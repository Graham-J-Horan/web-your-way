<script>
  import {
    selectedBlockIds,
    toggleBlock,
    totalPrice,
    BLOCKS,
    ALWAYS_INCLUDED_IDS,
  } from "../store/cart";

  const SVG_TOTAL_H = 600;
  const VIEW_H = 160;
  const SVG_W = 200;

  const BLOCK_SVG_Y: Record<string, number> = {
    "responsive-navbar": 12,
    "hero-section": 57,
    "trust-badges": 97,
    "service-highlights": 121,
    "fleet-showcase": 168,
    "pricing-table": 222,
    "services-reservation": 265,
    "portfolio-grid": 308,
    "google-reviews": 351,
    "faq-accordion": 395,
    "location-maps": 436,
    "contact-form": 475,
    "contact-form-alt": 512,
    "blog-engine": 539,
    "ai-personalization": 553,
    "whatsapp-strategy": 562,
    "performance-optimization": 570,
    "sticky-mobile-cta": 580,
    "footer-complex": 586,
  };

  const ALWAYS_ACTIVE = new Set(ALWAYS_INCLUDED_IDS);

  const svg = document.getElementById("page-schematic") as SVGSVGElement | null;
  const highlightBand = document.getElementById(
    "highlight-band",
  ) as SVGRectElement | null;
  const schematicCol = document.getElementById(
    "schematic-col",
  ) as HTMLElement | null;
  const sectionsGrid = document.getElementById(
    "sections-grid",
  ) as HTMLElement | null;
  const stickyTotal = document.getElementById("sticky-total-display");
  const stickyCount = document.getElementById("sticky-count-display");
  const schematicCount = document.getElementById("schematic-count");
  const schematicTotal = document.getElementById("schematic-total");
  const totalCTA = document.getElementById("total-price-display-cta");
  const footerLog = document.getElementById("footer-build-log");
  const navIndicator = document.getElementById("nav-indicator");
  const navLinks = document.querySelectorAll(".section-nav-link");

  // ── viewBox animation ──────────────────────────────────────────────────
  let currentVY = 0;
  let targetVY = 0;
  let rafId: number | null = null;

  function clampVY(y: number) {
    return Math.max(0, Math.min(y, SVG_TOTAL_H - VIEW_H));
  }

  function applyViewBox(y: number) {
    svg?.setAttribute("viewBox", `0 ${y.toFixed(2)} ${SVG_W} ${VIEW_H}`);
  }

  function animateViewBox() {
    const diff = targetVY - currentVY;
    if (Math.abs(diff) < 0.15) {
      currentVY = targetVY;
      applyViewBox(currentVY);
      rafId = null;
      return;
    }
    currentVY += diff * 0.12;
    applyViewBox(currentVY);
    rafId = requestAnimationFrame(animateViewBox);
  }

  function setTargetVY(svgCentreY: number) {
    targetVY = clampVY(svgCentreY - VIEW_H / 2);
    if (!rafId) rafId = requestAnimationFrame(animateViewBox);
  }

  // ── highlight band ─────────────────────────────────────────────────────
  const BAND_H = 38;
  let bandRafId: number | null = null;
  let currentBandY = 24;
  let targetBandY = 24;

  function animateBand() {
    const diff = targetBandY - currentBandY;
    if (Math.abs(diff) < 0.2) {
      currentBandY = targetBandY;
      if (highlightBand) {
        highlightBand.setAttribute("y", String(currentBandY));
        highlightBand.setAttribute("height", String(BAND_H));
        highlightBand.setAttribute("opacity", "0.08");
      }
      bandRafId = null;
      return;
    }
    currentBandY += diff * 0.14;
    if (highlightBand) {
      highlightBand.setAttribute("y", String(currentBandY));
      highlightBand.setAttribute("height", String(BAND_H));
      highlightBand.setAttribute("opacity", "0.08");
    }
    bandRafId = requestAnimationFrame(animateBand);
  }

  function setHighlightBand(svgY: number) {
    targetBandY = svgY - BAND_H / 2;
    if (!bandRafId) bandRafId = requestAnimationFrame(animateBand);
  }

  // ── Find active block — only considers cards within sections-grid ──────
  // Once the user has scrolled past sections-grid, tracking stops.
  // The schematic freezes on the last active block — appropriate since
  // the always-included and CTA sections don't correspond to SVG zones.

  const allCards = document.querySelectorAll("label[data-block-id]");

  function isGridInView(): boolean {
    if (!sectionsGrid) return true;
    const rect = sectionsGrid.getBoundingClientRect();
    // Grid is "in view" if its bottom edge is still below screen centre
    return rect.bottom > window.innerHeight * 0.4;
  }

  function findActiveBlock(): string | null {
    const screenMid = window.innerHeight / 2;
    let best: string | null = null;
    let bestDist = Infinity;

    allCards.forEach((card) => {
      const rect = card.getBoundingClientRect();
      const cardMid = rect.top + rect.height / 2;
      const dist = Math.abs(cardMid - screenMid);
      if (dist < bestDist) {
        bestDist = dist;
        best = (card as HTMLElement).dataset.blockId || null;
      }
    });
    return best;
  }

  let scrollRaf: number | null = null;
  let lastActiveBlock: string | null = null;

  function onScroll() {
    if (scrollRaf) return;
    scrollRaf = requestAnimationFrame(() => {
      scrollRaf = null;

      // Stop tracking once the user is past the selectable sections
      if (!isGridInView()) return;

      const blockId = findActiveBlock();
      if (!blockId || blockId === lastActiveBlock) return;
      lastActiveBlock = blockId;

      const svgY = BLOCK_SVG_Y[blockId];
      if (svgY === undefined) return;

      setTargetVY(svgY);
      setHighlightBand(svgY);
    });
  }

  window.addEventListener("scroll", onScroll, { passive: true });

  // ── Schematic opacity ──────────────────────────────────────────────────
  function updateSchematic(selectedIds: string[]) {
    document.querySelectorAll('[id^="bp-"]').forEach((el) => {
      const id = (el as HTMLElement).id.replace("bp-", "");
      const on = ALWAYS_ACTIVE.has(id) || selectedIds.includes(id);
      (el as SVGGElement).style.opacity = on ? "1" : "0.12";
      (el as SVGGElement).style.transition = "opacity 0.35s ease";
    });
    if (schematicCount) schematicCount.textContent = String(selectedIds.length);
    if (schematicTotal)
      schematicTotal.textContent = `€${totalPrice.get().toLocaleString()}`;
  }

  // ── Checkbox wiring ────────────────────────────────────────────────────
  const checkboxes = document.querySelectorAll(
    ".block-checkbox",
  ) as NodeListOf<HTMLInputElement>;
  selectedBlockIds.get().forEach((id) => {
    const cb = document.querySelector(
      `.block-checkbox[data-id="${id}"]`,
    ) as HTMLInputElement | null;
    if (cb) cb.checked = true;
  });

  checkboxes.forEach((checkbox) => {
    const id = checkbox.dataset.id;
    checkbox.addEventListener("change", () => {
      if (!id) return;
      const block = BLOCKS[id];
      toggleBlock(id);
      if (footerLog)
        footerLog.textContent = checkbox.checked
          ? `Added: ${block?.name || id}`
          : `Removed: ${block?.name || id}`;
      updateSchematic(selectedBlockIds.get());
    });
  });

  // ── Store subscriptions ────────────────────────────────────────────────
  totalPrice.subscribe((price) => {
    const fmt = `€${price.toLocaleString()}`;
    if (stickyTotal) stickyTotal.textContent = fmt;
    if (totalCTA) totalCTA.textContent = fmt;
    if (schematicTotal) schematicTotal.textContent = fmt;
  });

  selectedBlockIds.subscribe((ids) => {
    const n = ids.length;
    if (stickyCount)
      stickyCount.textContent =
        n === 0
          ? "Nothing selected yet"
          : `${n} item${n === 1 ? "" : "s"} selected`;
    if (schematicCount) schematicCount.textContent = String(n);
    updateSchematic(ids);
  });

  // ── Scroll spy nav ─────────────────────────────────────────────────────
  const navObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const id =
          entry.target.id ||
          (entry.target as HTMLElement).dataset.sectionId ||
          "";
        navLinks.forEach((link) => {
          const active = link.getAttribute("href")?.substring(1) === id;
          link.classList.toggle("text-on-background", active);
          link.classList.toggle("text-on-background/40", !active);
          if (active && navIndicator) {
            const el = link as HTMLElement;
            navIndicator.style.width = `${el.offsetWidth}px`;
            navIndicator.style.left = `${el.offsetLeft}px`;
            navIndicator.style.opacity = "1";
            link.scrollIntoView({ behavior: "smooth", inline: "nearest" });
          }
        });
      });
    },
    { rootMargin: "-15% 0px -55% 0px" },
  );

  document
    .querySelectorAll(
      'section[data-section-id], section[id="section-included"]',
    )
    .forEach((s) => navObserver.observe(s));

  // ── Mobile schematic toggle ────────────────────────────────────────────
  const schematicToggle = document.getElementById("schematic-toggle");
  const schematicContent = document.getElementById("schematic-content");
  const toggleIcon = document.getElementById("toggle-icon");
  let hasAutoOpened = false;

  if (schematicToggle && schematicContent) {
    schematicToggle.addEventListener("click", () => {
      const isExpanded =
        schematicToggle.getAttribute("aria-expanded") === "true";
      schematicToggle.setAttribute("aria-expanded", (!isExpanded).toString());

      if (!isExpanded) {
        schematicContent.classList.remove("hidden");
        toggleIcon?.classList.add("rotate-180");
        // Scroll schematic into view when opened
        setTimeout(() => {
          schematicContent.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        }, 100);
      } else {
        schematicContent.classList.add("hidden");
        toggleIcon?.classList.remove("rotate-180");
      }
    });
  }

  // Auto-expand schematic on mobile when user selects first item
  selectedBlockIds.subscribe((ids) => {
    if (!hasAutoOpened && ids.length > 0 && window.innerWidth < 1024) {
      if (schematicToggle && schematicContent) {
        const isExpanded =
          schematicToggle.getAttribute("aria-expanded") === "true";
        if (!isExpanded) {
          schematicToggle.click();
          hasAutoOpened = true;
        }
      }
    }
  });

  // ── Initial render ─────────────────────────────────────────────────────
  updateSchematic(selectedBlockIds.get());
  applyViewBox(0);
  requestAnimationFrame(onScroll);

  // ── Mobile Modal Preview ────────────────────────────────────────────────
  // Create modal elements dynamically (or add them directly to your HTML)
  const modalHTML = `
<div id="preview-modal" class="fixed inset-0 z-[200] bg-on-background/98 backdrop-blur-sm hidden flex-col" style="display: none;">
  <!-- Modal Header -->
  <div class="flex justify-between items-center p-4 border-b border-white/10 bg-on-background sticky top-0 z-10">
    <div>
      <h3 class="font-headline font-black text-white uppercase tracking-tighter text-xl">Live Preview</h3>
      <p class="text-white/40 text-[10px] uppercase tracking-widest mt-0.5">Your page — building in real time</p>
    </div>
    <button id="close-modal" class="text-white p-2 hover:bg-white/10 transition-colors rounded">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>

  <!-- Modal Content - Scrollable -->
  <div class="flex-1 overflow-y-auto p-4 space-y-6">
    <!-- Schematic Preview Card -->
    <div class="bg-white rounded-lg overflow-hidden border-[3px] border-on-background/20">
      <div class="p-3 bg-surface-container border-b border-on-background/10">
        <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant flex items-center gap-2">
          <span class="w-2 h-2 bg-secondary-container rounded-full animate-pulse"></span>
          LIVE VISUALISATION
        </p>
      </div>
      <div class="p-4">
        <svg
          id="modal-schematic"
          viewBox="0 0 200 160"
          xmlns="http://www.w3.org/2000/svg"
          width="100%"
          height="auto"
          preserveAspectRatio="xMidYMid meet"
          style="display:block;"
        >
          <!-- Same SVG content as your main schematic -->
          <!-- Copy ALL SVG elements from your original schematic here -->
        </svg>
      </div>
    </div>

    <!-- Selected Items Summary -->
    <div class="bg-surface-container-lowest rounded-lg border-[2px] border-on-background/10 overflow-hidden">
      <div class="p-4 border-b border-on-background/10 bg-surface-container">
        <h4 class="font-headline font-black text-sm uppercase tracking-tighter flex items-center gap-2">
          <span class="material-symbols-outlined text-secondary-container text-base">checklist</span>
          Selected Building Blocks
        </h4>
      </div>
      <div id="modal-selected-list" class="divide-y divide-on-background/10">
        <!-- Dynamic content -->
        <div class="p-8 text-center text-on-surface-variant text-sm italic">
          No blocks selected yet. Tap some items above to see them appear here.
        </div>
      </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-2 gap-3">
      <div class="bg-primary-container/10 p-4 rounded-lg border border-primary-container/20">
        <p class="text-[9px] font-black uppercase tracking-widest text-primary-container mb-1">Items Added</p>
        <p id="modal-count" class="font-headline font-black text-3xl tracking-tighter text-white">0</p>
      </div>
      <div class="bg-secondary-container/10 p-4 rounded-lg border border-secondary-container/20">
        <p class="text-[9px] font-black uppercase tracking-widest text-secondary-container mb-1">Your Estimate</p>
        <p id="modal-total" class="font-headline font-black text-3xl tracking-tighter text-secondary-container">€0</p>
      </div>
    </div>
  </div>

  <!-- Modal Footer CTA -->
  <div class="p-4 border-t border-white/10 bg-on-background sticky bottom-0">
    <a
      href="/summary-and-quote"
      class="block w-full bg-secondary-container text-on-background text-center py-4 px-6 font-headline font-black text-base uppercase tracking-wider hard-shadow hover:-translate-y-0.5 transition-all flex items-center justify-between group"
    >
      <span>Continue to Quote</span>
      <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
    </a>
    <p class="text-center text-white/30 text-[9px] uppercase tracking-widest mt-3">
      Free · No obligation · Your selections are saved
    </p>
  </div>
</div>
`;

  // Inject modal into body
  const modalContainer = document.createElement("div");
  modalContainer.innerHTML = modalHTML;
  document.body.appendChild(modalContainer);

  // Get modal elements
  const modal = document.getElementById("preview-modal");
  const modalSvg = document.getElementById("modal-schematic");
  const modalSelectedList = document.getElementById("modal-selected-list");
  const modalCount = document.getElementById("modal-count");
  const modalTotal = document.getElementById("modal-total");
  const closeModalBtn = document.getElementById("close-modal");

  // Function to update modal content
  function updateModal(selectedIds: string[], total: number) {
    // Update count and total
    if (modalCount) modalCount.textContent = String(selectedIds.length);
    if (modalTotal) modalTotal.textContent = `€${total.toLocaleString()}`;

    // Update schematic opacity in modal
    if (modalSvg) {
      document
        .querySelectorAll('#modal-schematic [id^="bp-"]')
        .forEach((el) => {
          const id = (el as HTMLElement).id.replace("bp-", "");
          const on = ALWAYS_ACTIVE.has(id) || selectedIds.includes(id);
          (el as SVGGElement).style.opacity = on ? "1" : "0.12";
        });
    }

    // Update selected items list
    if (modalSelectedList) {
      if (selectedIds.length === 0) {
        modalSelectedList.innerHTML = `
        <div class="p-8 text-center text-on-surface-variant text-sm italic">
          No blocks selected yet. Tap some items above to see them appear here.
        </div>
      `;
      } else {
        modalSelectedList.innerHTML = selectedIds
          .map((id) => {
            const block = BLOCKS[id];
            const meta = getBlockMeta(id);
            return `
          <div class="flex items-center justify-between p-4 hover:bg-white/5 transition-colors">
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-secondary-container text-base">${meta.icon}</span>
              <div>
                <p class="font-headline font-black text-sm uppercase tracking-tighter text-white">${meta.label}</p>
                <p class="text-white/40 text-[9px] uppercase tracking-widest">${block?.price ? `€${block.price}` : ""}</p>
              </div>
            </div>
            <span class="text-secondary-container font-mono text-sm font-bold">€${block?.price || 0}</span>
          </div>
        `;
          })
          .join("");
      }
    }
  }

  // Sticky mobile preview button
  const mobilePreviewBtn = document.createElement("button");
  mobilePreviewBtn.id = "mobile-preview-btn";
  mobilePreviewBtn.className =
    "fixed bottom-6 left-4 right-4 z-50 lg:hidden bg-on-background text-white border-[3px] border-secondary-container py-4 px-6 font-headline font-black uppercase tracking-wider hard-shadow flex items-center justify-between active:translate-y-0.5 transition-all";
  mobilePreviewBtn.innerHTML = `
  <span class="flex items-center gap-2">
    <span class="material-symbols-outlined">visibility</span>
    Live Preview
  </span>
  <span class="flex items-center gap-3">
    <span id="mobile-preview-count" class="text-secondary-container font-bold">0</span>
    <span class="text-white/40">|</span>
    <span id="mobile-preview-total" class="text-secondary-container font-bold">€0</span>
    <span class="material-symbols-outlined text-secondary-container">arrow_forward</span>
  </span>
`;
  document.body.appendChild(mobilePreviewBtn);

  const mobilePreviewCount = document.getElementById("mobile-preview-count");
  const mobilePreviewTotal = document.getElementById("mobile-preview-total");

  // Open modal
  mobilePreviewBtn.addEventListener("click", () => {
    const ids = selectedBlockIds.get();
    const total = totalPrice.get();
    updateModal(ids, total);
    if (modal) {
      modal.classList.remove("hidden");
      modal.style.display = "flex";
      document.body.style.overflow = "hidden"; // Prevent background scroll
    }
  });

  // Close modal
  if (closeModalBtn) {
    closeModalBtn.addEventListener("click", () => {
      if (modal) {
        modal.classList.add("hidden");
        modal.style.display = "none";
        document.body.style.overflow = "";
      }
    });
  }

  // Close modal on backdrop click
  if (modal) {
    modal.addEventListener("click", (e) => {
      if (e.target === modal) {
        modal.classList.add("hidden");
        modal.style.display = "none";
        document.body.style.overflow = "";
      }
    });
  }

  // Update mobile preview button stats
  function updateMobilePreviewButton(ids: string[], total: number) {
    if (mobilePreviewCount) mobilePreviewCount.textContent = String(ids.length);
    if (mobilePreviewTotal)
      mobilePreviewTotal.textContent = `€${total.toLocaleString()}`;

    // Change button appearance when items are selected
    if (ids.length > 0) {
      mobilePreviewBtn.classList.add(
        "border-secondary-container",
        "shadow-[0_4px_0_0_#C1F100]",
      );
    } else {
      mobilePreviewBtn.classList.remove(
        "border-secondary-container",
        "shadow-[0_4px_0_0_#C1F100]",
      );
      mobilePreviewBtn.style.transform = "";
    }
  }

  // ── Mobile preview button updates ────────────────────────────────────────
  function updateMobilePreviewButton(ids: string[], total: number) {
    if (mobilePreviewCount) mobilePreviewCount.textContent = String(ids.length);
    if (mobilePreviewTotal)
      mobilePreviewTotal.textContent = `€${total.toLocaleString()}`;

    // Visual feedback when items are selected
    if (ids.length > 0) {
      mobilePreviewBtn.classList.add("border-secondary-container");
      mobilePreviewBtn.style.boxShadow = "0 4px 0 0 #C1F100";
    } else {
      mobilePreviewBtn.classList.remove("border-secondary-container");
      mobilePreviewBtn.style.boxShadow = "";
    }
  }

  // Subscribe to selection changes
  selectedBlockIds.subscribe((ids) => {
    const total = totalPrice.get();
    updateMobilePreviewButton(ids, total);

    // Update modal if it's open
    if (modal && modal.style.display === "flex") {
      updateModal(ids, total);
    }
  });

  // Subscribe to price changes separately
  totalPrice.subscribe((total) => {
    const ids = selectedBlockIds.get();
    updateMobilePreviewButton(ids, total);

    if (modal && modal.style.display === "flex") {
      updateModal(ids, total);
    }
  });

  // Initial update
  updateMobilePreviewButton(selectedBlockIds.get(), totalPrice.get());
</script>
