---
interface Props {
	showDropdown?: boolean;
	isFunnel?: boolean;
	backHref?: string;
	backLabel?: string;
}

const {
	showDropdown = true,
	isFunnel = false,
	backHref = "/configurator",
	backLabel = "Back to Configurator",
} = Astro.props;
---

<header
  class="flex justify-between items-center w-full px-8 py-6 h-24 bg-background fixed top-0 z-100 border-b-[3px] border-on-background hard-shadow-sm transition-colors duration-150"
>
  <div
    class="text-3xl font-black text-on-background tracking-widest font-headline"
  >
    <a href="/">WEB-YOUR-WAY</a>
  </div>

  <nav class="hidden md:flex gap-12 items-center h-full">
    <a
      class="font-headline font-bold uppercase tracking-tighter text-on-background hover:bg-secondary-container hover:text-on-background transition-colors duration-150 px-2 py-1"
      href="/how-it-works">How it Works</a
    >
    <a
      class="font-headline font-bold uppercase tracking-tighter text-on-background hover:bg-secondary-container hover:text-on-background transition-colors duration-150 px-2 py-1"
      href="/terminology">Terminology</a
    >
    <a
      class="font-headline font-bold uppercase tracking-tighter text-on-background hover:bg-secondary-container hover:text-on-background transition-colors duration-150 px-2 py-1"
      href="/catalog">Technical Catalog</a
    >
  </nav>

  <div class="flex items-center gap-6">
    <!-- Theme Toggle -->
    <button
      type="button"
      id="theme-toggle"
      class="flex items-center justify-center w-10 h-10 border-2 border-on-background hover:bg-secondary-container transition-colors duration-150 group"
    >
      <span
        class="material-symbols-outlined text-xl text-on-background dark:hidden"
        aria-hidden="true">dark_mode</span
      >
      <span
        class="material-symbols-outlined text-xl text-on-background hidden dark:block"
        aria-hidden="true">light_mode</span
      >
    </button>

    {
      isFunnel ? (
        <a
          href={backHref}
          class="bg-surface text-on-background border-[3px] border-on-background px-6 py-3 font-headline font-bold uppercase text-sm hard-shadow-sm hover:bg-secondary-container transition-all flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-sm" aria-hidden="true">tune</span>
          {backLabel}
        </a>
      ) : (
        showDropdown && (
          <div class="relative" x-data="{ open: false }">
            <button
              type="button"
              @click="open = !open"
              @keydown.escape="open = false"
              :aria-expanded="open"
              aria-haspopup="true"
              class="bg-primary-container text-on-primary border-[3px] border-on-background px-6 py-3 font-headline font-bold uppercase text-sm hard-shadow-sm active:translate-x-0.5 active:translate-y-0.5 active:shadow-none transition-all flex items-center gap-2"
            >
              Start Building
              <span 
                class="material-symbols-outlined text-sm transition-transform"
                :class="{ 'rotate-180': open }"
                aria-hidden="true"
              >
                expand_more
              </span>
            </button>

            <div 
              x-show="open"
              @click.away="open = false"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 translate-y-[-10px]"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 translate-y-[-10px]"
              class="absolute right-0 mt-2 w-64 bg-background border-[3px] border-on-background hard-shadow z-110"
              style="display: none;"
            >
              <div class="px-6 py-4 border-b-[3px] border-on-background bg-surface-container">
                <h4 class="font-headline text-sm font-bold text-on-background">
                  Building Blocks
                </h4>
                <p class="text-[10px] uppercase font-bold tracking-widest opacity-60">
                  Configurator v1.0
                </p>
              </div>
              <nav class="flex flex-col">
                <a
                  class="flex items-center gap-4 px-6 py-4 text-on-background border-b-[3px] border-on-background hover:bg-[#C1F100] transition-colors font-headline text-xs uppercase font-bold"
                  href="/configurator"
                  @click="open = false"
                >
                  <span class="material-symbols-outlined text-lg" aria-hidden="true">
                    grid_view
                  </span>{" "}
                  Layouts
                </a>
                <a
                  class="flex items-center gap-4 px-6 py-4 text-on-background border-b-[3px] border-on-background hover:bg-[#8A2BE2] hover:text-white transition-colors font-headline text-xs uppercase font-bold"
                  href="/typography"
                  @click="open = false"
                >
                  <span class="material-symbols-outlined text-lg" aria-hidden="true">
                    format_size
                  </span>{" "}
                  Typography
                </a>
                <a
                  class="flex items-center gap-4 px-6 py-4 text-on-background border-b-[3px] border-on-background hover:bg-[#8A2BE2] hover:text-white transition-colors font-headline text-xs uppercase font-bold"
                  href="/colour-palette"
                  @click="open = false"
                >
                  <span class="material-symbols-outlined text-lg" aria-hidden="true">palette</span>{" "}
                  Colour Palette
                </a>
                <a
                  class="flex items-center gap-4 px-6 py-4 text-on-background border-b-[3px] border-on-background hover:bg-[#8A2BE2] hover:text-white transition-colors font-headline text-xs uppercase font-bold"
                  href="/configurator"
                  @click="open = false"
                >
                  <span class="material-symbols-outlined text-lg" aria-hidden="true">
                    extension
                  </span>{" "}
                  Components
                </a>
                <a
                  class="flex items-center gap-4 px-6 py-4 text-on-background hover:bg-[#8A2BE2] hover:text-white transition-colors font-headline text-xs uppercase font-bold"
                  href="/configurator"
                  @click="open = false"
                >
                  <span class="material-symbols-outlined text-lg" aria-hidden="true">
                    folder_open
                  </span>{" "}
                  Assets
                </a>
              </nav>
            </div>
          </div>
        )
      )
    }
  </div>
</header>

<script is:inline>
  const themeToggle = document.getElementById("theme-toggle");
  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }
</script>